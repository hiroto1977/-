{
  "appId": "com.servicehub.desktop",
  "productName": "Service Hub",
  "directories": {
    "output": "release",
    "buildResources": "build"
  },
  "files": [
    "dist/**/*",
    "dist-electron/**/*",
    "build/icon.png",
    "package.json"
  ],
  "mac": { "target": "dmg", "icon": "build/icon.png", "category": "public.app-category.productivity" },
  "win": { "target": "nsis", "icon": "build/icon.png" },
  "linux": { "target": "AppImage", "icon": "build/icon.png", "category": "Utility" }
}
