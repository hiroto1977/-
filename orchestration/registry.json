{
  "$schema": "./registry.schema.json",
  "version": 2,
  "policy": {
    "description": "AIオーケストレーションの進化ルール。CEO配下に役員層→管理職層→一般職層の3階層を置き、作業サイクル(round)ごとにチーム数を単調増加させ、領域を細分化しながら精度を保つ。",
    "minTeamsForRound": [
      { "round": 1, "minTeams": 2 },
      { "round": 2, "minTeams": 2 },
      { "round": 3, "minTeams": 3 },
      { "round": 4, "minTeams": 5 },
      { "round": 5, "minTeams": 6 },
      { "round": 6, "minTeams": 7 }
    ],
    "growthRule": "各 round の teamCount は前 round 以上であること (単調増加)。新領域の追加で細分化する。",
    "roleSeparation": "並列=調査/設計 (read-only Agent)、直列=実装+全ゲート検証 (オーケストレーター)。共有ファイルへの同時書込みを避ける。",
    "qualityGate": "各実装コミット前に typecheck / lint / test / verify:all / build:web の全 green を必須とする。",
    "hierarchy": {
      "description": "AIは CEO 以外の3階層に配置する。指揮系統: CEO → 役員層(executives) → 管理職層(managers) → 一般職層(teams)。",
      "layers": [
        { "layer": "ceo", "title": "最高経営責任者", "staffedByAI": false, "responsibility": "全体方針の決定・最終承認・全ゲート検証 (オーケストレーター本体が担う。AIエージェントには配置しない)" },
        { "layer": "executive", "title": "役員層", "staffedByAI": true, "responsibility": "担当領域群の戦略・優先順位付け・リスク監督。配下の管理職を束ねる" },
        { "layer": "manager", "title": "管理職層", "staffedByAI": true, "responsibility": "部の論点設計・調査チームの編成と割当・品質確認の一次窓口。配下の一般職を束ねる" },
        { "layer": "staff", "title": "一般職層", "staffedByAI": true, "responsibility": "担当ドメインの調査・設計 (read-only Agent)。実装の素案を提供" }
      ]
    }
  },
  "org": {
    "ceo": { "id": "ceo", "title": "CEO (オーケストレーター)", "staffedByAI": false, "note": "AIには配置しない最上位。実装・全ゲート検証・コミットを担う本体。" },
    "executives": [
      { "id": "cfo", "title": "財務・税務担当役員 (CFO)", "reportsTo": "ceo", "owns": ["mgr-tax", "mgr-funding", "mgr-payroll"] },
      { "id": "cio", "title": "投資・資産担当役員 (CIO)", "reportsTo": "ceo", "owns": ["mgr-investment", "mgr-household"] },
      { "id": "coo", "title": "経営・分析担当役員 (COO)", "reportsTo": "ceo", "owns": ["mgr-management"] },
      { "id": "cqo", "title": "品質・セキュリティ担当役員 (CQO)", "reportsTo": "ceo", "owns": ["mgr-quality"] }
    ],
    "managers": [
      { "id": "mgr-tax", "title": "税務部長", "reportsTo": "cfo", "teams": ["tax-income", "tax-resident", "tax-deductions", "tax-credits", "tax-separate", "tax-consumption"] },
      { "id": "mgr-funding", "title": "資金調達部長", "reportsTo": "cfo", "teams": ["funding-cashflow", "funding-cost", "funding-scenario"] },
      { "id": "mgr-payroll", "title": "給与・人件費部長", "reportsTo": "cfo", "teams": ["payroll"] },
      { "id": "mgr-investment", "title": "投資部長", "reportsTo": "cio", "teams": ["real-estate", "mutual-funds"] },
      { "id": "mgr-household", "title": "家計・為替部長", "reportsTo": "cio", "teams": ["savings-planning", "fx-currency"] },
      { "id": "mgr-management", "title": "経営分析部長", "reportsTo": "coo", "teams": ["kpi-analysis", "management-integration", "depreciation", "growth-analysis", "revenue-forecast"] },
      { "id": "mgr-quality", "title": "品質保証部長", "reportsTo": "cqo", "teams": ["quality-audit", "security"] }
    ]
  },
  "teams": [
    { "id": "tax-income", "domain": "税務(所得税)", "focus": "所得税・速算表・復興特別所得税", "active": true, "manager": "mgr-tax" },
    { "id": "tax-resident", "domain": "税務(住民税)", "focus": "住民税・所得割・均等割・調整控除・税額控除", "active": true, "manager": "mgr-tax" },
    { "id": "tax-deductions", "domain": "税務(所得控除)", "focus": "配偶者/扶養/社保/生命保険/医療費/iDeCo等", "active": true, "manager": "mgr-tax" },
    { "id": "tax-credits", "domain": "税務(税額控除)", "focus": "住宅ローン/配当/ふるさと納税", "active": true, "manager": "mgr-tax" },
    { "id": "tax-separate", "domain": "税務(分離課税)", "focus": "退職所得/譲渡所得/一時所得/公的年金", "active": true, "manager": "mgr-tax" },
    { "id": "tax-consumption", "domain": "税務(消費税)", "focus": "本則/簡易/2割特例/インボイス", "active": true, "manager": "mgr-tax" },
    { "id": "funding-cashflow", "domain": "資金調達(資金繰り)", "focus": "月次CF/ランウェイ/DSCR/返済", "active": true, "manager": "mgr-funding" },
    { "id": "funding-cost", "domain": "資金調達(コスト)", "focus": "実効調達コスト率/自己負担比率/質スコア", "active": true, "manager": "mgr-funding" },
    { "id": "funding-scenario", "domain": "資金調達(シナリオ)", "focus": "採択確率/期待値/3シナリオ残高", "active": true, "manager": "mgr-funding" },
    { "id": "kpi-analysis", "domain": "経営(KPI/BEP)", "focus": "損益分岐点/目標利益/販売数量/価格", "active": true, "manager": "mgr-management" },
    { "id": "real-estate", "domain": "投資(不動産)", "focus": "利回り/CCR/イールドギャップ", "active": true, "manager": "mgr-investment" },
    { "id": "mutual-funds", "domain": "投資(投信)", "focus": "複利/シャープレシオ/積立", "active": true, "manager": "mgr-investment" },
    { "id": "security", "domain": "セキュリティ", "focus": "パスワード強度/エントロピー/突破時間", "active": true, "manager": "mgr-quality" },
    { "id": "quality-audit", "domain": "品質監査", "focus": "端数処理/ゼロ除算/境界値/復興税順序の監査", "active": true, "role": "audit", "manager": "mgr-quality" },
    { "id": "savings-planning", "domain": "家計/貯蓄計画", "focus": "目標達成積立/72の法則/緊急予備資金", "active": true, "manager": "mgr-household" },
    { "id": "fx-currency", "domain": "為替/外貨", "focus": "外貨換算/為替損益/実効レート", "active": true, "manager": "mgr-household" },
    { "id": "payroll", "domain": "給与/賞与", "focus": "賞与の源泉徴収/月次手取り/通勤手当非課税限度", "active": true, "manager": "mgr-payroll" },
    { "id": "depreciation", "domain": "減価償却", "focus": "定額法/定率法/耐用年数/少額減価償却", "active": true, "manager": "mgr-management" },
    { "id": "management-integration", "domain": "経営統合", "focus": "経営指標の集約・スコアカード・健全性診断", "active": true, "manager": "mgr-management" },
    { "id": "growth-analysis", "domain": "経営(成長性)", "focus": "売上前期比成長率/CAGR/トレンド・スコアカード成長性連携", "active": true, "manager": "mgr-management" },
    { "id": "revenue-forecast", "domain": "経営(予測)", "focus": "着地見込み/トレンド外挿/予算実績差異", "active": true, "manager": "mgr-management" }
  ],
  "rounds": [
    { "round": 1, "teamCount": 2, "teams": ["tax-deductions", "tax-credits"], "shipped": ["所得税1000円切捨て", "住民税1000円切捨て"] },
    { "round": 2, "teamCount": 2, "teams": ["funding-cashflow", "funding-cost"], "shipped": ["資金調達レーダー", "課税区分/税引後手残り"] },
    { "round": 3, "teamCount": 3, "teams": ["funding-cashflow", "tax-credits", "funding-scenario"], "shipped": ["元金均等返済", "3シナリオ残高", "一時所得"] },
    { "round": 4, "teamCount": 5, "teams": ["tax-deductions", "quality-audit", "funding-cost", "tax-credits", "tax-separate"], "shipped": ["セルフメディケーション", "境界値ハードニング", "消費税区分", "住宅ローン所得制限", "譲渡所得"] },
    { "round": 5, "teamCount": 6, "teams": ["kpi-analysis", "quality-audit", "real-estate", "tax-consumption", "tax-separate", "funding-scenario"], "shipped": ["公的年金等控除", "KPI目標利益/販売数量"] },
    { "round": 6, "teamCount": 7, "teams": ["real-estate", "tax-resident", "kpi-analysis", "funding-scenario", "tax-separate", "security", "quality-audit"], "shipped": ["概算取得費5%特例", "パスワード強度評価"] },
    { "round": 7, "teamCount": 8, "teams": ["real-estate", "tax-resident", "kpi-analysis", "funding-scenario", "savings-planning", "fx-currency", "payroll", "depreciation"], "shipped": ["不動産CCR・イールドギャップ"] },
    { "round": 8, "teamCount": 9, "teams": ["tax-resident", "kpi-analysis", "funding-scenario", "savings-planning", "fx-currency", "payroll", "depreciation", "tax-separate", "quality-audit"], "shipped": ["住民税の配当割控除・株式譲渡所得割控除・一般寄附金税額控除"] },
    { "round": 9, "teamCount": 10, "teams": ["kpi-analysis", "funding-scenario", "savings-planning", "fx-currency", "payroll", "depreciation", "tax-separate", "real-estate", "security", "quality-audit"], "shipped": ["KPI価格変更シミュレーション"] },
    { "round": 10, "teamCount": 11, "teams": ["management-integration", "kpi-analysis", "funding-scenario", "savings-planning", "fx-currency", "payroll", "depreciation", "tax-separate", "real-estate", "security", "quality-audit"], "shipped": ["経営スコアカード(収益性/安全性/資金繰り/成長性の集約)"] },
    { "round": 11, "teamCount": 12, "teams": ["growth-analysis", "management-integration", "kpi-analysis", "funding-scenario", "savings-planning", "fx-currency", "payroll", "depreciation", "tax-separate", "real-estate", "security", "quality-audit"], "shipped": ["スコアカード成長性の自動連携(前期比売上成長率)"] },
    { "round": 12, "teamCount": 13, "teams": ["growth-analysis", "revenue-forecast", "management-integration", "kpi-analysis", "funding-scenario", "savings-planning", "fx-currency", "payroll", "depreciation", "tax-separate", "real-estate", "security", "quality-audit"], "shipped": ["売上成長性の深掘り(CAGR・移動平均トレンド)"] }
  ],
  "backlog": [
    { "id": "scorecard-growth", "team": "growth-analysis", "title": "スコアカード成長性の自動連携(KPI実績の前期比売上成長率)", "priority": 1, "status": "shipped" },
    { "id": "scorecard-liquidity", "team": "management-integration", "title": "スコアカード資金繰り(DSCR/ランウェイ)の会計連携データ自動連携", "priority": 2, "status": "blocked", "note": "永続化された資金調達データ源 (会計連携/freee) が前提。snapshot のデモ値を健全性スコアに流すと実態を誤表示するため、データ源の整備まで保留。" },
    { "id": "growth-cagr", "team": "growth-analysis", "title": "売上CAGR・移動平均トレンド・季節調整成長率", "priority": 3, "status": "shipped" },
    { "id": "revenue-forecast", "team": "revenue-forecast", "title": "着地見込み(トレンド外挿)・予算実績差異(BVA)", "priority": 4, "status": "designed" },
    { "id": "real-estate-ccr", "team": "real-estate", "title": "自己資金回収率(CCR)・イールドギャップ", "priority": 1, "status": "shipped" },
    { "id": "resident-dividend-levy", "team": "tax-resident", "title": "住民税の配当割控除・株式譲渡所得割控除・一般寄附金税額控除", "priority": 2, "status": "shipped" },
    { "id": "kpi-price-sim", "team": "kpi-analysis", "title": "価格変更シミュレーション(値上げ/値下げのBEP影響)", "priority": 3, "status": "shipped" },
    { "id": "funding-diversification", "team": "funding-scenario", "title": "資金調達の多様化スコア(種別集中度・HHI)", "priority": 4, "status": "designed" },
    { "id": "savings-goal", "team": "savings-planning", "title": "目標達成積立額・72の法則・緊急予備資金", "priority": 5, "status": "designed" },
    { "id": "fx-conversion", "team": "fx-currency", "title": "外貨換算・為替損益・実効レート", "priority": 6, "status": "designed" },
    { "id": "bonus-withholding", "team": "payroll", "title": "賞与の源泉徴収税額・通勤手当の非課税限度", "priority": 7, "status": "designed" },
    { "id": "depreciation-methods", "team": "depreciation", "title": "減価償却(定額法/定率法)・少額減価償却特例", "priority": 8, "status": "designed" }
  ]
}
