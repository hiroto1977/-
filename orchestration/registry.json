{
  "$schema": "./registry.schema.json",
  "version": 1,
  "policy": {
    "description": "AIオーケストレーションの進化ルール。作業サイクル(round)ごとにチーム数を単調増加させ、領域を細分化しながら精度を保つ。",
    "minTeamsForRound": [
      { "round": 1, "minTeams": 2 },
      { "round": 2, "minTeams": 2 },
      { "round": 3, "minTeams": 3 },
      { "round": 4, "minTeams": 5 },
      { "round": 5, "minTeams": 6 },
      { "round": 6, "minTeams": 7 }
    ],
    "growthRule": "各 round の teamCount は前 round 以上であること (単調増加)。新領域の追加で細分化する。",
    "roleSeparation": "並列=調査/設計 (read-only Agent)、直列=実装+全ゲート検証 (オーケストレーター)。共有ファイルへの同時書込みを避ける。",
    "qualityGate": "各実装コミット前に typecheck / lint / test / verify:all / build:web の全 green を必須とする。"
  },
  "teams": [
    { "id": "tax-income", "domain": "税務(所得税)", "focus": "所得税・速算表・復興特別所得税", "active": true },
    { "id": "tax-resident", "domain": "税務(住民税)", "focus": "住民税・所得割・均等割・調整控除・税額控除", "active": true },
    { "id": "tax-deductions", "domain": "税務(所得控除)", "focus": "配偶者/扶養/社保/生命保険/医療費/iDeCo等", "active": true },
    { "id": "tax-credits", "domain": "税務(税額控除)", "focus": "住宅ローン/配当/ふるさと納税", "active": true },
    { "id": "tax-separate", "domain": "税務(分離課税)", "focus": "退職所得/譲渡所得/一時所得/公的年金", "active": true },
    { "id": "tax-consumption", "domain": "税務(消費税)", "focus": "本則/簡易/2割特例/インボイス", "active": true },
    { "id": "funding-cashflow", "domain": "資金調達(資金繰り)", "focus": "月次CF/ランウェイ/DSCR/返済", "active": true },
    { "id": "funding-cost", "domain": "資金調達(コスト)", "focus": "実効調達コスト率/自己負担比率/質スコア", "active": true },
    { "id": "funding-scenario", "domain": "資金調達(シナリオ)", "focus": "採択確率/期待値/3シナリオ残高", "active": true },
