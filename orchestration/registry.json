{
  "$schema": "./registry.schema.json",
  "version": 2,
  "policy": {
    "description": "AIオーケストレーションの進化ルール。人間のCEO(オーナー)の直下にCOO(オーケストレーター=Claude本体)を置き、その配下に役員層→管理職層→一般職層を展開する。作業サイクル(round)ごとにチーム数を単調増加させ、領域を細分化しながら精度を保つ。",
    "minTeamsForRound": [
      {
        "round": 1,
        "minTeams": 2
      },
      {
        "round": 2,
        "minTeams": 2
      },
      {
        "round": 3,
        "minTeams": 3
      },
      {
        "round": 4,
        "minTeams": 5
      },
      {
        "round": 5,
        "minTeams": 6
      },
      {
        "round": 6,
        "minTeams": 7
      }
    ],
    "growthRule": "各 round の teamCount は前 round 以上であること (単調増加)。新領域の追加で細分化する。",
    "roleSeparation": "並列=調査/設計 (read-only Agent)、直列=実装+全ゲート検証 (オーケストレーター)。共有ファイルへの同時書込みを避ける。",
    "qualityGate": "各実装コミット前に typecheck / lint / test / verify:all / build:web の全 green を必須とする。",
    "hierarchy": {
      "description": "指揮系統: CEO(人間=オーナー) → COO(オーケストレーター=Claude本体) → 役員層(executives) → 管理職層(managers) → 一般職層(teams)。CEOとCOOは研究Agentには配置しない (CEO=あなた, COO=実装本体)。",
      "layers": [
        {
          "layer": "ceo",
          "title": "最高経営責任者 (オーナー=あなた)",
          "staffedByAI": false,
          "human": true,
          "responsibility": "経営方針・優先順位の決定と最終承認。人間の最高責任者"
        },
        {
          "layer": "coo",
          "title": "最高執行責任者 (オーケストレーター=Claude)",
          "staffedByAI": false,
          "responsibility": "CEOの方針を実行に落とし込み、AI組織全体を統括。実装・全ゲート検証・コミットを担う本体"
        },
        {
          "layer": "executive",
          "title": "役員層",
          "staffedByAI": true,
          "responsibility": "担当領域群の戦略・優先順位付け・リスク監督。COO配下で管理職を束ねる"
        },
        {
          "layer": "secretariat",
          "title": "秘書室",
          "staffedByAI": true,
          "responsibility": "各役員に1室(4体のAIチーム)を常設し、日程・資料・連絡・記録で役員を継続サポート。指揮系統(ライン)ではなく支援(スタッフ)機能"
        },
        {
          "layer": "manager",
          "title": "管理職層",
          "staffedByAI": true,
          "responsibility": "部の論点設計・調査チームの編成と割当・品質確認の一次窓口。配下の一般職を束ねる"
        },
        {
          "layer": "staff",
          "title": "一般職層",
          "staffedByAI": true,
          "responsibility": "担当ドメインの調査・設計 (read-only Agent)。実装の素案を提供"
        }
      ]
    }
  },
  "org": {
    "ceo": {
      "id": "ceo",
      "title": "CEO (オーナー・最高経営責任者)",
      "staffedByAI": false,
      "human": true,
      "note": "事業オーナー(あなた)。経営方針・優先順位の決定と最終承認を担う人間の最高責任者。AIには配置しない。"
    },
    "coo": {
      "id": "coo",
      "title": "COO (最高執行責任者・オーケストレーター)",
      "reportsTo": "ceo",
      "staffedByAI": false,
      "owns": [
        "cfo",
        "chro",
        "cso",
        "cio",
        "cqo"
      ],
      "note": "Claude本体(あなたのCOO)。CEOの方針を受けてAI組織全体の実行を統括し、実装・全ゲート検証・コミットを担う。部門は直轄せず、配下の5役員を通じて運営する(監督と実務の分離)。"
    },
    "executives": [
