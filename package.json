{
  "name": "service-hub-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop dashboard skeleton for GitHub, WordPress.com, Atlassian, Notion, Google Drive, Calendar, Gmail, Slack, and Canva.",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && electron-builder",
    "build:renderer": "tsc -b && vite build",
    "build:web": "tsc -b && vite build && node scripts/inline-html.cjs",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc -b --noEmit --force",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run src/main --coverage --coverage.include=src/main/** --coverage.reporter=text --coverage.reporter=json-summary",
    "test:property": "vitest run src/main/__tests__/property.test.ts",
    "mutate": "stryker run",
    "mutate:triage": "node scripts/triage-mutations.cjs",
    "mutate:next": "node scripts/suggest-next-kill.cjs",
    "quality": "npm run typecheck && npm run test && npm run test:cov",
    "quality:report": "node scripts/quality-report.cjs",
    "verify:arch": "node scripts/verify-architecture.cjs",
    "verify:orchestration": "node scripts/verify-orchestration.cjs",
    "orchestration:plan": "node scripts/verify-orchestration.cjs --plan",
    "orchestrate": "node scripts/orchestrate.cjs",
    "orchestrate:status": "node scripts/orchestrate.cjs status",
    "orchestrate:dispatch": "node scripts/orchestrate.cjs dispatch",
    "orchestrate:import-requests": "node scripts/orchestrate.cjs import-requests",
    "build:demo": "node scripts/build-counseling-demo.cjs",
    "build:deliberation-demo": "node scripts/build-deliberation-demo.cjs",
    "lint:forbidden": "node scripts/lint-forbidden-patterns.cjs",
    "lint:imports": "node scripts/check-import-boundaries.cjs",
    "lint:docs": "node scripts/cross-doc-consistency.cjs",
    "lint:test-coverage": "node scripts/lint-test-coverage.cjs",
    "lint:shell": "node scripts/lint-shell.cjs",
    "verify:all": "npm run verify:arch && npm run lint:forbidden && npm run lint:imports && npm run lint:docs && npm run lint:test-coverage && npm run lint:shell && npm run verify:orchestration",
    "smoke": "xvfb-run -a electron --no-sandbox scripts/screenshot.cjs",
    "scaffold": "node scripts/scaffold-service.cjs",
    "gen:econ-chart": "node scripts/gen-econ-history-chart.cjs",
    "gen:econ-asset-chart": "node scripts/gen-econ-asset-chart.cjs",
    "exp:runtime": "xvfb-run -a electron --no-sandbox scripts/runtime-security-exp.cjs",
    "exp:soak": "xvfb-run -a electron --no-sandbox scripts/soak-test.cjs",
    "exp:overflow": "xvfb-run -a electron --no-sandbox scripts/overflow-check.cjs",
    "build:landing": "node scripts/build-landing.cjs",
    "build:research-demo": "node scripts/build-research-demo.cjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.9",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "fake-indexeddb": "^6.2.5",
    "fast-check": "^4.8.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.59.3",
    "vite": "^6.0.3",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
