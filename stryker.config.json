{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "_commentScope": "Scoped to pure-logic modules. The IPC handlers (main.ts) + secrets.ts depend on the live Electron runtime — mocking them just to mutate would be high-noise, low-signal.",
  "mutate": [
    "src/main/oauth.ts",
    "src/main/clients/types.ts",
    "src/main/clients/skills.ts",
    "src/main/clients/security.ts",
    "src/main/clients/atlassian.ts",
    "src/main/clients/github.ts",
    "src/main/clients/gmail.ts",
    "src/main/clients/slack.ts",
    "src/main/clients/ollama.ts",
    "src/main/clients/kpi.ts",
    "src/main/clients/stocks.ts",
    "src/main/clients/business.ts",
    "src/main/clients/teamradar.ts",
    "src/main/clients/templates.ts",
    "src/main/clients/home.ts",
    "src/main/clients/library.ts",
    "src/main/clients/settings.ts",
    "src/main/clients/wordpress.ts",
    "src/main/clients/notion.ts",
    "src/main/clients/calendar.ts",
    "src/main/clients/emotions.ts",
    "src/main/clients/drive.ts",
    "src/main/clients/canva.ts",
    "src/main/clients/cloudflare.ts",
    "src/renderer/security/vault.ts",
    "src/renderer/security/autoLock.ts",
    "src/renderer/security/mnemonic.ts",
    "src/renderer/network/proxy.ts",
    "src/renderer/oauth/pkce.ts",
    "src/renderer/library/library.ts",
    "src/renderer/fs/fsa.ts"
  ],
  "testRunner": "vitest",
  "vitest": {
    "configFile": "vitest.config.ts"
  },
  "reporters": ["clear-text", "json"],
  "coverageAnalysis": "perTest",
  "_thresholdsRationale": "🏆 100.00% TOTAL restored AGAIN, this time after dashboard export introduction (renderDashboardHtml + escapeHtml + defaultDashboardPath + isSafeDashboardPath + exportDashboardImpl). break=99.8 (buffer 0.2). Recovery arc: 95.79 → 98.88 → 99.94 → 100.00 across 3 ratchet steps. Third successful new-scope introduction + recovery (stocks → advisor → dashboard).",
  "thresholds": { "high": 100, "low": 99.9, "break": 99.8 },
  "timeoutMS": 30000,
  "concurrency": 4,
  "tempDirName": ".stryker-tmp",
  "incremental": true,
  "incrementalFile": ".stryker-incremental.json"
}
